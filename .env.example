# â”€â”€â”€ WhatsApp (Meta Cloud API) â€” Reminder Templates â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Default: FAKE. Set to META to enable real WhatsApp Business template messages (reminders).
# Prerequisites: Meta Business account, verified WhatsApp Business API, approved templates.
WHATSAPP_PROVIDER="FAKE"
META_WHATSAPP_ACCESS_TOKEN=""
META_WHATSAPP_PHONE_NUMBER_ID=""
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
META_WHATSAPP_APP_SECRET=""

# â”€â”€â”€ WhatsApp Auto Booking Link Reply â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Sends automatic Turkish booking link replies to inbound WhatsApp messages.
# Default: FAKE (console.log only, no real messages). Set to META or TWILIO to enable.
# Per-org settings stored in WhatsAppAutoReplySettings DB table.
WHATSAPP_AUTO_REPLY_ENABLED=false
WHATSAPP_TEXT_PROVIDER=FAKE
WHATSAPP_DEFAULT_COOLDOWN_HOURS=24

# Twilio WhatsApp (optional alternative provider for auto-reply)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""

# Public booking URL base (used to generate booking links in auto-replies)
# Example: https://randevo.com/booking  â†’  full URL: https://randevo.com/booking/berber-demo
NEXT_PUBLIC_BOOKING_BASE_URL=http://localhost:3000/booking

# â”€â”€â”€ Google Calendar â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Default: FAKE (console.log only). Set to GOOGLE to enable real Calendar sync.
# Prerequisites: Google Cloud project with Calendar API enabled, OAuth 2.0 credentials.
CALENDAR_PROVIDER="FAKE"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/calendar/callback"

# â”€â”€â”€ AI Chatbot (Anthropic) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Default: DISABLED (returns a polite fallback message). Set to ANTHROPIC to enable.
# Get API key from https://console.anthropic.com
AI_PROVIDER="DISABLED"
ANTHROPIC_API_KEY=""

# â”€â”€â”€ Accounting Integration â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Default: NONE (no external accounting sync). Set to XERO or QUICKBOOKS to enable.
# Note: This is NOT a tax compliance tool. Records are for business tracking only.
ACCOUNTING_PROVIDER="NONE"
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""

