# ─── Database ────────────────────────────────────────────────────────────────
# Local development: SQLite (no Docker needed, zero setup)
DATABASE_URL="file:./dev.db"

# Production (Vercel + Neon/Supabase): change schema.prisma provider to "postgresql" and use:
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── Auth.js / NextAuth ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Stripe (Test Mode) ───────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_placeholder"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"

# Stripe Price IDs (Test Mode)
STRIPE_STARTER_PRICE_ID="price_test_starter_placeholder"
STRIPE_PRO_PRICE_ID="price_test_pro_placeholder"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Leave empty to use fake/log mode (recommended for local dev)
RESEND_API_KEY=""
EMAIL_FROM="noreply@slotpilot.app"

# ─── SMS (Twilio) ─────────────────────────────────────────────────────────────
# Default: FAKE (console.log only, no real SMS). Set to TWILIO to enable real SMS.
SMS_PROVIDER="FAKE"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ─── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
# Default: FAKE. Set to META to enable real WhatsApp Business messages.
# Prerequisites: Meta Business account, verified WhatsApp Business API, approved templates.
WHATSAPP_PROVIDER="FAKE"
META_WHATSAPP_ACCESS_TOKEN=""
META_WHATSAPP_PHONE_NUMBER_ID=""
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=""

# ─── Google Calendar ──────────────────────────────────────────────────────────
# Default: FAKE (console.log only). Set to GOOGLE to enable real Calendar sync.
# Prerequisites: Google Cloud project with Calendar API enabled, OAuth 2.0 credentials.
CALENDAR_PROVIDER="FAKE"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/calendar/callback"

# ─── AI Chatbot (Anthropic) ───────────────────────────────────────────────────
# Default: DISABLED (returns a polite fallback message). Set to ANTHROPIC to enable.
# Get API key from https://console.anthropic.com
AI_PROVIDER="DISABLED"
ANTHROPIC_API_KEY=""

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
