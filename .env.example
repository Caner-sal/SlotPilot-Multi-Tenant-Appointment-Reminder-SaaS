# ─── Database ────────────────────────────────────────────────────────────────
# Local development: SQLite (no Docker needed, zero setup)
DATABASE_URL="file:./dev.db"

# Production (Vercel + Neon/Supabase): change schema.prisma provider to "postgresql" and use:
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── Auth.js / NextAuth ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Stripe (Test Mode) ───────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_placeholder"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"

# Stripe Price IDs (Test Mode)
STRIPE_STARTER_PRICE_ID="price_test_starter_placeholder"
STRIPE_PRO_PRICE_ID="price_test_pro_placeholder"

# ─── Türkiye Fiyatlandırma (Stripe TRY Price ID'leri) ────────────────────────
# Stripe dashboard'da TRY cinsinden oluşturulan price ID'leri
STRIPE_TR_STARTER_PRICE_ID=""
STRIPE_TR_PRO_PRICE_ID=""

# ─── Türkiye Yerel Ödeme Sağlayıcıları ───────────────────────────────────────
# Default: MANUAL_BANK_TRANSFER (EFT/havale talimatları üretir)
# Diğer seçenekler: STRIPE, IYZICO, PAYTR, PARAM
PAYMENT_PROVIDER="MANUAL_BANK_TRANSFER"

# Manuel Banka Havalesi (PAYMENT_PROVIDER=MANUAL_BANK_TRANSFER)
BANK_TRANSFER_IBAN=""
BANK_TRANSFER_ACCOUNT_HOLDER=""
BANK_TRANSFER_BANK_NAME=""
BANK_TRANSFER_DESCRIPTION_PREFIX="SLOTPILOT"

# iyzico (PAYMENT_PROVIDER=IYZICO)
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_BASE_URL=""

# PayTR (PAYMENT_PROVIDER=PAYTR)
PAYTR_MERCHANT_ID=""
PAYTR_MERCHANT_KEY=""
PAYTR_MERCHANT_SALT=""

# Param POS (PAYMENT_PROVIDER=PARAM)
PARAM_CLIENT_CODE=""
PARAM_CLIENT_USERNAME=""
PARAM_CLIENT_PASSWORD=""
PARAM_GUID=""

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Leave empty to use fake/log mode (recommended for local dev)
RESEND_API_KEY=""
EMAIL_FROM="noreply@slotpilot.app"

# ─── SMS (Twilio) ─────────────────────────────────────────────────────────────
# Default: FAKE (console.log only, no real SMS). Set to TWILIO to enable real SMS.
SMS_PROVIDER="FAKE"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ─── WhatsApp (Meta Cloud API) — Reminder Templates ──────────────────────────
# Default: FAKE. Set to META to enable real WhatsApp Business template messages (reminders).
# Prerequisites: Meta Business account, verified WhatsApp Business API, approved templates.
WHATSAPP_PROVIDER="FAKE"
META_WHATSAPP_ACCESS_TOKEN=""
META_WHATSAPP_PHONE_NUMBER_ID=""
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
META_WHATSAPP_APP_SECRET=""

# ─── WhatsApp Auto Booking Link Reply ─────────────────────────────────────────
# Sends automatic Turkish booking link replies to inbound WhatsApp messages.
# Default: FAKE (console.log only, no real messages). Set to META or TWILIO to enable.
# Per-org settings stored in WhatsAppAutoReplySettings DB table.
WHATSAPP_AUTO_REPLY_ENABLED=false
WHATSAPP_TEXT_PROVIDER=FAKE
WHATSAPP_DEFAULT_COOLDOWN_HOURS=24

# Twilio WhatsApp (optional alternative provider for auto-reply)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""

# Public booking URL base (used to generate booking links in auto-replies)
# Example: https://slotpilot.com/booking  →  full URL: https://slotpilot.com/booking/berber-demo
NEXT_PUBLIC_BOOKING_BASE_URL=http://localhost:3000/booking

# ─── Google Calendar ──────────────────────────────────────────────────────────
# Default: FAKE (console.log only). Set to GOOGLE to enable real Calendar sync.
# Prerequisites: Google Cloud project with Calendar API enabled, OAuth 2.0 credentials.
CALENDAR_PROVIDER="FAKE"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/calendar/callback"

# ─── AI Chatbot (Anthropic) ───────────────────────────────────────────────────
# Default: DISABLED (returns a polite fallback message). Set to ANTHROPIC to enable.
# Get API key from https://console.anthropic.com
AI_PROVIDER="DISABLED"
ANTHROPIC_API_KEY=""

# ─── Accounting Integration ──────────────────────────────────────────────────
# Default: NONE (no external accounting sync). Set to XERO or QUICKBOOKS to enable.
# Note: This is NOT a tax compliance tool. Records are for business tracking only.
ACCOUNTING_PROVIDER="NONE"
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""

# ─── KVKK / Açık Rıza Sürümleri ──────────────────────────────────────────────
# Format: YYYY-MM — sürüm değişince consent logları yeni versiyonu gösterir
KVKK_NOTICE_VERSION="2026-01"
EXPLICIT_CONSENT_VERSION="2026-01"
MARKETING_CONSENT_VERSION="2026-01"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
