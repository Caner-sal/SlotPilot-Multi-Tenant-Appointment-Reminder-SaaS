generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Local dev: sqlite (file:./dev.db) — no Docker needed
  // Production: change to "postgresql" and set DATABASE_URL to your Postgres connection string
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum PlatformRole {
  USER
  SUPERADMIN
}

enum AppRole {
  OWNER
  STAFF_MEMBER
}

enum MemberRole {
  OWNER
  ADMIN
  STAFF
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  NOT_REQUIRED
  PENDING_PAYMENT
  PAID
  FAILED
  REFUNDED
}

enum ReminderType {
  EMAIL
  SMS
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
  INCOMPLETE
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  passwordHash   String
  platformRole   PlatformRole @default(USER)
  appRole        AppRole      @default(OWNER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  memberships  OrganizationMember[]
  auditLogs    AuditLog[]
  staffProfile Staff?

  @@index([email])
  @@index([platformRole])
}

model Organization {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?
  phone          String?
  email          String?
  address        String?
  timezone       String   @default("UTC")
  bookingEnabled Boolean  @default(true)
  suspended      Boolean  @default(false)
  smsEnabled     Boolean  @default(false)
  logoUrl        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  members       OrganizationMember[]
  services      Service[]
  staff         Staff[]
  customers     Customer[]
  appointments  Appointment[]
  reminders     Reminder[]
  subscription  Subscription?
  auditLogs     AuditLog[]
  availability  AvailabilityRule[]
  staffInvites  StaffInvite[]
  locations     Location[]
  payments      Payment[]

  @@index([slug])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           MemberRole   @default(STAFF)
  createdAt      DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model Service {
  id                 String   @id @default(cuid())
  organizationId     String
  name               String
  description        String?
  durationMinutes    Int
  priceCents         Int      @default(0)
  currency           String   @default("TRY")
  depositRequired    Boolean  @default(false)
  depositAmountCents Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staffServices StaffService[]
  appointments  Appointment[]

  @@index([organizationId])
  @@index([organizationId, isActive])
}

model Staff {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?  @unique
  name           String
  email          String?
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  staffServices StaffService[]
  availability  AvailabilityRule[]
  appointments  Appointment[]
  invites       StaffInvite[]

  @@index([organizationId])
  @@index([organizationId, isActive])
}

model Payment {
  id              String   @id @default(cuid())
  organizationId  String
  appointmentId   String
  stripeEventId   String   @unique
  sessionId       String
  amountCents     Int
  currency        String   @default("TRY")
  status          String   @default("paid")
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointment  Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([appointmentId])
  @@index([stripeEventId])
}

model Location {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?
  phone          String?
  timezone       String   @default("UTC")
  isActive       Boolean  @default(true)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([organizationId])
  @@index([organizationId, isActive])
}

model StaffInvite {
  id             String    @id @default(cuid())
  organizationId String
  staffId        String
  token          String    @unique
  email          String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staff        Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([organizationId])
}

model StaffService {
  id        String @id @default(cuid())
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
  @@index([staffId])
  @@index([serviceId])
}

model AvailabilityRule {
  id             String    @id @default(cuid())
  organizationId String
  staffId        String
  dayOfWeek      DayOfWeek
  startTime      String
  endTime        String
  isActive       Boolean   @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staff        Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@index([staffId])
  @@index([organizationId])
}

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  fullName       String
  email          String?
  phone          String?
  smsOptIn       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([organizationId])
  @@index([organizationId, email])
}

model Appointment {
  id             String            @id @default(cuid())
  organizationId String
  serviceId      String
  staffId        String
  customerId     String
  locationId              String?
  startTime               DateTime
  endTime                 DateTime
  status                  AppointmentStatus @default(PENDING)
  paymentStatus           PaymentStatus     @default(NOT_REQUIRED)
  stripeCheckoutSessionId String?
  notes                   String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  service      Service       @relation(fields: [serviceId], references: [id])
  staff        Staff         @relation(fields: [staffId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  location     Location?     @relation(fields: [locationId], references: [id])
  reminders    Reminder[]
  payments     Payment[]

  @@index([organizationId])
  @@index([organizationId, startTime])
  @@index([staffId, startTime])
  @@index([status])
}

model Reminder {
  id                String         @id @default(cuid())
  organizationId    String
  appointmentId     String
  type              ReminderType   @default(EMAIL)
  scheduledAt       DateTime
  status            ReminderStatus @default(PENDING)
  sentAt            DateTime?
  errorMessage      String?
  provider          String?
  providerMessageId String?
  retryCount        Int            @default(0)
  createdAt         DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointment  Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status, scheduledAt])
  @@index([appointmentId])
}

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String             @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([stripeCustomerId])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  actorUserId    String?
  action         String
  entityType     String?
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([actorUserId])
  @@index([createdAt])
}
