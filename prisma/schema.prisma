generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Local dev: sqlite (file:./dev.db) — no Docker needed
  // Production: change to "postgresql" and set DATABASE_URL to your Postgres connection string
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum PlatformRole {
  USER
  SUPERADMIN
}

enum AppRole {
  OWNER
  STAFF_MEMBER
}

enum MemberRole {
  OWNER
  ADMIN
  STAFF
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  NOT_REQUIRED
  PENDING_PAYMENT
  PAID
  FAILED
  REFUNDED
}

enum ReminderType {
  EMAIL
  SMS
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
  INCOMPLETE
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  emailVerified  DateTime?
  passwordHash   String
  platformRole   PlatformRole @default(USER)
  appRole        AppRole      @default(OWNER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  memberships  OrganizationMember[]
  auditLogs    AuditLog[]
  staffProfile Staff?

  @@index([email])
  @@index([platformRole])
}

model Organization {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?
  phone          String?
  email          String?
  address        String?
  province       String?
  district       String?
  postalCode     String?
  timezone       String   @default("UTC")
  bookingEnabled Boolean  @default(true)
  suspended      Boolean  @default(false)
  smsEnabled        Boolean  @default(false)
  whatsappEnabled     Boolean  @default(false)
  marketplaceEnabled  Boolean  @default(false)
  category            String?
  city                String?
  coverImageUrl       String?
  aiChatbotEnabled    Boolean  @default(false)
  faqText             String?
  chatbotTone         String?
  logoUrl             String?
  ratingAverage       Float?
  reviewCount         Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  members       OrganizationMember[]
  services      Service[]
  staff         Staff[]
  customers     Customer[]
  appointments  Appointment[]
  reminders     Reminder[]
  subscription  Subscription?
  auditLogs     AuditLog[]
  availability  AvailabilityRule[]
  staffInvites  StaffInvite[]
  locations            Location[]
  payments             Payment[]
  calendarConnections  CalendarConnection[]
  revenueLedger        RevenueLedger[]
  chatConversations    ChatConversation[]
  invoiceRecords       InvoiceRecord[]
  accountingConnection AccountingConnection?
  consentLogs          ConsentLog[]
  deletionRequests     DataDeletionRequest[]
  invoiceProfile       InvoiceProfile?
  closedDays           BusinessClosedDay[]
  whatsAppAutoReplySettings  WhatsAppAutoReplySettings?
  whatsAppInboundMessages    WhatsAppInboundMessage[]
  whatsAppAutoReplyLogs      WhatsAppAutoReplyLog[]
  whatsAppContactPreferences WhatsAppContactPreference[]

  @@index([slug])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           MemberRole   @default(STAFF)
  createdAt      DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model Service {
  id                 String   @id @default(cuid())
  organizationId     String
  name               String
  description        String?
  durationMinutes    Int
  priceCents         Int      @default(0)
  currency           String   @default("TRY")
  depositRequired    Boolean  @default(false)
  depositAmountCents Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staffServices StaffService[]
  appointments  Appointment[]

  @@index([organizationId])
  @@index([organizationId, isActive])
}

model Staff {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?  @unique
  name           String
  email          String?
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  staffServices StaffService[]
  availability  AvailabilityRule[]
  appointments  Appointment[]
  invites       StaffInvite[]

  @@index([organizationId])
  @@index([organizationId, isActive])
}

model Payment {
  id              String   @id @default(cuid())
  organizationId  String
  appointmentId   String
  stripeEventId   String   @unique
  sessionId       String
  amountCents     Int
  currency        String   @default("TRY")
  status          String   @default("paid")
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointment  Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([appointmentId])
  @@index([stripeEventId])
}

model Location {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?
  province       String?
  district       String?
  postalCode     String?
  phone          String?
  timezone       String   @default("UTC")
  isActive       Boolean  @default(true)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([organizationId])
  @@index([organizationId, isActive])
}

model StaffInvite {
  id             String    @id @default(cuid())
  organizationId String
  staffId        String
  token          String    @unique
  email          String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staff        Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([organizationId])
}

model StaffService {
  id        String @id @default(cuid())
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
  @@index([staffId])
  @@index([serviceId])
}

model AvailabilityRule {
  id             String    @id @default(cuid())
  organizationId String
  staffId        String
  dayOfWeek      DayOfWeek
  startTime      String
  endTime        String
  isActive       Boolean   @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staff        Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@index([staffId])
  @@index([organizationId])
}

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  fullName       String
  email          String?
  phone          String?
  province       String?
  district       String?
  smsOptIn       Boolean  @default(true)
  whatsappOptIn  Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([organizationId])
  @@index([organizationId, email])
}

model Appointment {
  id             String            @id @default(cuid())
  organizationId String
  serviceId      String
  staffId        String
  customerId     String
  locationId              String?
  startTime               DateTime
  endTime                 DateTime
  status                  AppointmentStatus @default(PENDING)
  paymentStatus           PaymentStatus     @default(NOT_REQUIRED)
  stripeCheckoutSessionId String?
  calendarEventId         String?
  notes                   String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  service      Service       @relation(fields: [serviceId], references: [id])
  staff        Staff         @relation(fields: [staffId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  location     Location?     @relation(fields: [locationId], references: [id])
  reminders    Reminder[]
  payments     Payment[]

  @@index([organizationId])
  @@index([organizationId, startTime])
  @@index([staffId, startTime])
  @@index([status])
}

model Reminder {
  id                String         @id @default(cuid())
  organizationId    String
  appointmentId     String
  type              ReminderType   @default(EMAIL)
  scheduledAt       DateTime
  status            ReminderStatus @default(PENDING)
  sentAt            DateTime?
  errorMessage      String?
  provider          String?
  providerMessageId String?
  retryCount        Int            @default(0)
  channel           String?        @default("EMAIL")
  createdAt         DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointment  Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status, scheduledAt])
  @@index([appointmentId])
}

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String             @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([stripeCustomerId])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  actorUserId    String?
  action         String
  entityType     String?
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([actorUserId])
  @@index([createdAt])
}

model RevenueLedger {
  id             String   @id @default(cuid())
  organizationId String
  appointmentId  String?
  paymentId      String?
  type           String
  amountCents    Int
  currency       String   @default("TRY")
  status         String   @default("recorded")
  metadata       String?
  recordedAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, recordedAt])
}

model ChatConversation {
  id             String        @id @default(cuid())
  organizationId String
  sessionId      String        @unique
  createdAt      DateTime      @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]

  @@index([organizationId])
}

model ChatMessage {
  id             String          @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime        @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model InvoiceRecord {
  id             String   @id @default(cuid())
  organizationId String
  appointmentId  String?
  paymentId      String?
  amountCents    Int
  currency       String   @default("TRY")
  status         String   @default("draft")
  issuedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model BusinessClosedDay {
  id                String   @id @default(cuid())
  organizationId    String
  date              String
  reason            String?
  isHolidayOverride Boolean  @default(false)
  createdAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date])
  @@index([organizationId])
}

model InvoiceProfile {
  id                 String   @id @default(cuid())
  organizationId     String   @unique
  invoiceType        String   @default("INDIVIDUAL")
  companyTitle       String?
  taxOffice          String?
  taxNumber          String?
  identityNumber     String?
  invoiceProvince    String?
  invoiceDistrict    String?
  invoiceAddressLine String?
  invoiceEmail       String?
  invoicePhone       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ConsentLog {
  id                             String   @id @default(cuid())
  organizationId                 String
  customerId                     String?
  privacyNoticeAcknowledged      Boolean  @default(false)
  explicitConsentGiven           Boolean  @default(false)
  appointmentNotificationConsent Boolean  @default(true)
  marketingConsent               Boolean  @default(false)
  consentVersion                 String
  consentIp                      String?
  consentUserAgent               String?
  createdAt                      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, customerId])
}

model DataDeletionRequest {
  id             String   @id @default(cuid())
  organizationId String
  customerId     String?
  email          String
  reason         String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
}

model AccountingConnection {
  id             String   @id @default(cuid())
  organizationId String   @unique
  provider       String
  accessToken    String?
  refreshToken   String?
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model CalendarConnection {
  id                    String    @id @default(cuid())
  organizationId        String
  staffId               String?
  provider              String    @default("GOOGLE")
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  expiresAt             DateTime?
  calendarId            String?
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@index([organizationId])
  @@index([staffId])
}

// ─── WhatsApp Auto Booking Link Reply ────────────────────────────────────────
// provider values:  FAKE | META_CLOUD_API | TWILIO_WHATSAPP
// replyMode values: ALWAYS | KEYWORD_ONLY | DISABLED
// status values:    PENDING | SENT | SKIPPED | FAILED
// (String fields used instead of enums for SQLite compatibility)

model WhatsAppAutoReplySettings {
  id                 String   @id @default(cuid())
  organizationId     String   @unique
  enabled            Boolean  @default(false)
  provider           String   @default("FAKE")
  phoneNumberId      String?
  replyMode          String   @default("ALWAYS")
  cooldownHours      Int      @default(24)
  triggerKeywords    String   @default("[]")
  messageTemplate    String   @default("Merhaba 👋\nRandevu almak için linkimizi kullanabilirsiniz:\n{{bookingUrl}}\n\nBu linkten hizmet seçebilir, uygun saatleri görebilir ve randevunuzu oluşturabilirsiniz.\nİnsan desteği için bu mesaja yazmaya devam edebilirsiniz.")
  includeBookingLink Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model WhatsAppInboundMessage {
  id                String   @id @default(cuid())
  organizationId    String
  providerMessageId String   @unique
  fromPhone         String
  toPhone           String
  messageText       String?
  rawPayload        String
  receivedAt        DateTime @default(now())

  organization  Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  autoReplyLogs WhatsAppAutoReplyLog[]

  @@index([organizationId])
  @@index([organizationId, fromPhone])
  @@index([providerMessageId])
}

model WhatsAppAutoReplyLog {
  id               String    @id @default(cuid())
  inboundMessageId String
  organizationId   String
  customerPhone    String
  replyText        String?
  bookingUrl       String?
  status           String    @default("PENDING")
  errorMessage     String?
  sentAt           DateTime?
  createdAt        DateTime  @default(now())

  inboundMessage WhatsAppInboundMessage @relation(fields: [inboundMessageId], references: [id], onDelete: Cascade)
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([inboundMessageId])
  @@index([organizationId, customerPhone])
}

model WhatsAppContactPreference {
  id                             String    @id @default(cuid())
  organizationId                 String
  phone                          String
  isBlocked                      Boolean   @default(false)
  lastAutoReplyAt                DateTime?
  marketingConsent               Boolean   @default(false)
  appointmentNotificationConsent Boolean   @default(true)
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([organizationId, phone])
}

model VerificationToken {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([email, token])
}

