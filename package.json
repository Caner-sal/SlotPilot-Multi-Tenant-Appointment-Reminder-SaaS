{
  "name": "randevo",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <27",
    "npm": ">=10"
  },
  "packageManager": "npm@11.12.1",
  "scripts": {
    "check:node": "node scripts/check-node.js",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "dev": "node scripts/dev-runner.js",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/eslint/bin/eslint.js . --max-warnings=0",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "test:e2e": "node .\\node_modules\\playwright\\cli.js test",
    "prisma:validate": "node ./node_modules/prisma/build/index.js validate",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate",
    "prisma:dbpush": "node ./node_modules/prisma/build/index.js db push --skip-generate",
    "prisma:migrate:status": "node ./node_modules/prisma/build/index.js migrate status",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node node_modules/tsx/dist/cli.mjs prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "audit:districts": "node ./node_modules/tsx/dist/cli.mjs scripts/audit-turkey-districts.ts",
    "check:turkey-locations": "node ./node_modules/tsx/dist/cli.mjs scripts/validate-turkey-location-data.ts",
    "check:translations": "node ./node_modules/tsx/dist/cli.mjs scripts/check-translations.ts",
    "i18n:check": "node ./node_modules/tsx/dist/cli.mjs scripts/check-translations.ts",
    "phase:gate": "npm run check:node && npm run env:check && npm run check:secrets && npm run check:logs && npm run check:encoding && npm run validate:skills && npm run agent:check && node ./node_modules/typescript/bin/tsc --noEmit && npm run lint && node ./node_modules/vitest/vitest.mjs run && node ./node_modules/next/dist/bin/next build && npm run prisma:validate && npm run prisma:generate && npm run prisma:migrate:status",
    "validate:skills": "node scripts/validate-skills.js",
    "check:secrets": "node scripts/check-no-secrets.js",
    "agent:check": "node scripts/agent-check.js",
    "env:check": "node ./node_modules/tsx/dist/cli.mjs scripts/check-production-env.ts",
    "check:logs": "node ./node_modules/tsx/dist/cli.mjs scripts/check-console-usage.ts",
    "check:encoding": "node ./node_modules/tsx/dist/cli.mjs scripts/check-encoding.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@prisma/client": "^6.8.2",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.2.2",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.2.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.511.0",
    "next": "15.5.18",
    "next-auth": "^5.0.0-beta.28",
    "next-intl": "^4.11.2",
    "react": "^19.0.0",
    "react-day-picker": "^9.7.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.56.3",
    "resend": "^4.5.1",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.5.0",
    "dotenv": "^16.6.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "prisma": "^6.8.2",
    "tailwindcss": "^4",
    "tsx": "^4.19.3",
    "typescript": "5.8.2",
    "vitest": "^3.1.4"
  }
}
