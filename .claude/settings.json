{
  "permissions": {
    "allow": [
      "PowerShell(npm --version)",
      "PowerShell(npm *)",
      "PowerShell(npx *)",
      "PowerShell(node *)",
      "PowerShell(git *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/)",
      "Bash(netstat -ano)",
      "Bash(awk '{print $5}')",
      "Bash(taskkill /PID 53924 /F)",
      "PowerShell(Stop-Process -Id 53924 -Force -ErrorAction SilentlyContinue)"
    ]
  }
}
